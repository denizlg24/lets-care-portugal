# --- Database ---
# MongoDB connection string (Atlas or self-hosted)
MONGODB_URI=mongodb://localhost:27017/lets-care-portugal

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL the auth server is reachable at
BETTER_AUTH_URL=http://localhost:3000
# Public app URL used by the auth client in the browser
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Root user (consumed by scripts/seed.ts at build time) ---
ROOT_USER_EMAIL=
ROOT_USER_PASSWORD=
ROOT_USER_NAME=Root

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Storage service (blog media uploads) ---
# Self-hosted storage API (TUS uploads + share links)
STORAGE_API_URL=
STORAGE_API_KEY=
# Optional folder overrides (defaults shown)
# STORAGE_IMAGE_UPLOAD_PATH=uploads/images
# STORAGE_FILE_UPLOAD_PATH=uploads/files

# --- HTML resource thumbnails ---
# System Chromium/Chrome binary used to render cover thumbnails for uploaded
# HTML materials (pedagogic resources). Optional: without it, HTML uploads
# still work but get no thumbnail. Common values:
#   Ubuntu:  /usr/bin/chromium-browser
#   Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROMIUM_EXECUTABLE_PATH=

# --- Resend (transactional email) ---
RESEND_API_KEY=
# Verified sender, e.g. "LeTs Care Portugal <noreply@letscare.pt>"
RESEND_FROM_EMAIL=
